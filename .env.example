# Optional. If both are set the API will use LibreTranslate.
# Example public host: https://libretranslate.com (requires API key)
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# When unset, the translator returns a clearly-marked stub so the full flow
# (upload → extract → "translate" → generate → download) can be tested without
# external services.
